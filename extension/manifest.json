{
  "manifest_version": 3,
  "name": "TradingView Chrome MCP Connector",
  "version": "0.2.0",
  "description": "Connects your local tradingview-chrome-mcp server to TradingView for AI-assisted Pine Script development.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "scripting",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*",
    "ws://localhost/*",
    "https://www.tradingview.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TradingView MCP"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tradingview.com/*"],
      "js": ["error_observer.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected/commands.js", "injected/pine-injector.js"],
      "matches": ["https://www.tradingview.com/*"]
    }
  ]
}
