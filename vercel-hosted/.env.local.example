# Supabase telemetry (disable with TELEMETRY_ENABLED=0)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TELEMETRY_ENABLED=1

# Telemetry allow-list. Only these parameter keys are persisted.
TELEMETRY_ALLOWED_KEYS=symbol,ticker,timeframe

# API-key auth for SSE endpoints (comma-separated fallback / static keys).
MCP_API_KEYS=key_a,key_b,key_c

# Upstash Redis for cross-region serverless sessions.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Vercel KV alternative (only needed if not using Upstash directly).
# KV_URL=https://your-kv.vercel-storage.com
# KV_REST_API_TOKEN=your-kv-token

# Tool backend: mock | market-data-api
TOOL_BACKEND=mock

# Hosted approval behavior. Serverless cannot use an interactive dashboard.
TV_AUTO_APPROVE_DESTRUCTIVE=1

# Runtime log level.
TV_LOG_LEVEL=info

# Static feature-flag overrides (used when Supabase flags are unavailable).
# FLAG_DISABLE_TELEMETRY=0
# FLAG_READ_ONLY_MODE=0
# FLAG_DISABLE_DESTRUCTIVE_TOOLS=0
